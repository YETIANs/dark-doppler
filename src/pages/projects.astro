---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <h1>我的趣味作品 / 收藏</h1>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 2rem;">
    
    <!-- 作品1：CS2 音乐盒 -->
    <div style="border: 1px solid #eee; border-radius: 12px; padding: 1rem; overflow: hidden;">
      <img src="/cs2_musicbox.png" alt="CS2 音乐盒" style="width: 100%; border-radius: 8px;">
      <h3 style="margin: 1rem 0 0.5rem;">CS2 趣味音乐盒</h3>
      <p style="color: #666;">《CS2》StatTrak™ 音乐盒「ISOxo - 非人类」魔改版本，记录 MVP 次数，MVP 时高奏凯歌。</p>
    </div>

    <!-- 作品2：伊蕾娜 GIF -->
    <div style="border: 1px solid #eee; border-radius: 12px; padding: 1rem; overflow: hidden;">
      <img src="/yilena.gif" alt="伊蕾娜" style="width: 100%; border-radius: 8px;">
      <h3 style="margin: 1rem 0 0.5rem;">魔女之旅 - 伊蕾娜</h3>
      <p style="color: #666;">《魔女之旅》主角伊蕾娜 Q 版动图，俏皮可爱的经典表情包。</p>
    </div>

    <!-- 作品3：藤田琴音玩偶 -->
    <div style="border: 1px solid #eee; border-radius: 12px; padding: 1rem; overflow: hidden;">
      <img src="/futata_plush.jpg" alt="藤田琴音玩偶" style="width: 100%; border-radius: 8px;">
      <h3 style="margin: 1rem 0 0.5rem;">藤田琴音毛绒玩偶</h3>
      <p style="color: #666;">《学园偶像大师》藤田琴音「努努」玩偶，经典“嘘”手势表情包来源。</p>
    </div>

    <!-- 作品4：猫咪表情包 -->
    <div style="border: 1px solid #eee; border-radius: 12px; padding: 1rem; overflow: hidden;">
      <img src="/cat_meme.gif" alt="猫咪表情包" style="width: 100%; border-radius: 8px;">
      <h3 style="margin: 1rem 0 0.5rem;">慵懒猫咪表情包</h3>
      <p style="color: #666;">经典摆烂情绪表情包，表达无所谓、慵懒的日常状态。</p>
    </div>

  </div>
</Layout>